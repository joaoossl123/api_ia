# Copie para .env e ajuste (pasta backend/)

HOSPEDEIRO_API=127.0.0.1
PORTA_API=8000

# Chave Google AI Studio — https://aistudio.google.com/apikey
CHAVE_API_GEMINI=

# Modelos (free tier: prefira *-flash-lite)
NOME_MODELO_GEMINI=gemini-2.0-flash-lite
NOME_MODELO_GEMINI_BACKUP=gemini-flash-lite-latest

# Reduz consumo de cota (evita HTTP 429)
GEMINI_MAX_CANDIDATOS_LOTE=18
TRECHO_CANDIDATO_GEMINI=2500
GEMINI_LOTE=true
GEMINI_TENTATIVAS_429=2
GEMINI_PAUSA_429_SEGUNDOS=45

# true = não chama Gemini (só motor local, sem mensagem de quota)
PREFERIR_MOTOR_LOCAL=false

# Motor alternativo: hibrido = PyResparser + Resume Matcher + Gemini (opcional)
MOTOR_ANALISE_VAGA=padrao
USAR_PYRESPARSER=true
HIBRIDO_USAR_GEMINI=true

# true = falha se Gemini não responder (sem fallback local)
APENAS_GEMINI=false
